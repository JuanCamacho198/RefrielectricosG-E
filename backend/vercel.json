{
  "version": 2,
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- ./",
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/docs",
      "dest": "src/main.ts"
    },
    {
      "src": "/docs/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/health",
      "dest": "src/main.ts"
    }
  ]
}
