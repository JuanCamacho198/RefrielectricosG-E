# Base URLs (Vercel Production) - UPDATE THESE
BASE_URL_BACKEND=https://your-backend-vercel-url.vercel.app
BASE_URL_FRONTEND=https://your-frontend-vercel-url.vercel.app
FRONTEND_URL=https://your-frontend-vercel-url.vercel.app

PORT=4000

# VERCEL POSTGRES (NEON)
POSTGRES_PRISMA_URL=
